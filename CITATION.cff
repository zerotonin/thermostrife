cff-version: 1.2.0
message: "If you use this software, please cite it as below."
title: "ThermoStrife: historical-uprisings temperature companion to ThermoKourt"
type: software
version: "0.1.0"
date-released: "2026-05-25"
license: MIT
url: "https://github.com/zerotonin/thermostrife"
repository-code: "https://github.com/zerotonin/thermostrife"
authors:
  - family-names: Geurten
    given-names: "Bart R.H."
    orcid: "https://orcid.org/0000-0002-1816-3241"
    affiliation: "Department of Zoology, University of Otago, Dunedin, New Zealand"
keywords:
  - climate-conflict
  - heat-aggression
  - historical-uprisings
  - case-crossover
